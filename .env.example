# Keep seeded starter data visible on first launch (default)
# Set to false for a clean app with no preloaded entries.
VITE_USE_SEED_DATA=true

# Optional: enable TMDB enrichment during import
# VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Optional: server-side Letterboxd batch enricher endpoint
# Example: https://your-enricher.vercel.app/api/enrich-letterboxd
# VITE_BATCH_ENRICHER_URL=https://your-enricher-domain/api/enrich-letterboxd

# Optional: enable Spotify playlist import in-browser
# Create a Spotify app and add your site URL as the redirect URI.
# For GitHub Pages, this is usually:
# https://your-username.github.io/your-repo-name/
# VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Optional override if your redirect URI differs from the current page URL:
# VITE_SPOTIFY_REDIRECT_URI=https://your-site-url/
